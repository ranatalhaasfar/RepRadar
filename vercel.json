{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/outscraper-search.js":  { "maxDuration": 60 },
    "api/outscraper-reviews.js": { "maxDuration": 60 },
    "api/analyze-reviews.js":    { "maxDuration": 30 },
    "api/generate-insights.js":  { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}
